#include <bits/stdc++.h>

using namespace std;
int leftover(int x, int y) {
    if (x==0) return y;
    if (y==0) return x;
    if (x==y) return (x+y)/2;
    if (x>y) return leftover((x%y),y);
    else return leftover(x,(y%x));
}
int main() {
    // your code goes here
    int t;
    cin >> t;
    while (t--) {
        int x, y;
        cin >> x >> y;
        cout << 2*leftover(x, y) << endl;
    }
}