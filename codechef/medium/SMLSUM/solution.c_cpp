#include <bits/stdc++.h>

using namespace std;

int main() {
    // your code goes here
    int t;
    cin>>t;
    while(t--){
        int n,q;
        cin>>n>>q;
        int a[n],b[n],x[q];
        for(int i=0;i<n;i++) cin>>a[i];
        for(int i=0;i<n;i++) cin>>b[i];
        for(int i=0;i<q;i++) cin>>x[i];
        for(int i=0;i<q;i++){
        int sum=0;
            for(int j=0;j<n;j++){
                if(a[j]<=x[i]) sum=sum+b[j];
            }
            cout<<sum<<' ';
        }
    }
}