#include <bits/stdc++.h>
using namespace std;

int main() {
	// your code goes here
    int t;
    cin>>t;
    while(t--){
        int n;
        cin>>n;
        string arr[n];
        int a=0,b=0;
        for(int i=0;i<n;i++) cin>>arr[i];
        for(int i=0;i<n;i++){
            if (arr[i]=="START38") a+=1;
            else b+=1;
        }
        cout<<a<<' '<<b<<endl;
    }
}
