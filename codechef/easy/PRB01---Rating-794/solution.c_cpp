#include <bits/stdc++.h>
using namespace std;

int main() {
	// your code goes here
    int t;
    cin>>t;
    while(t--){
        int prime=1;;
        int n;
        cin>>n;
        if(n==1) prime=0;
        else{
            for(int i=2;i<n;i++){
                if((n%i)==0){
                    prime=0;
                }
            }
            
        }
        if(prime==1) cout<<"YES"<<endl;
        else if(prime==0) cout<<"NO"<<endl;
    }
}
